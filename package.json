    "@radix-ui/react-tooltip": "^1.1.2",
    "better-sqlite3": "^11.1.2",
    "chardet": "^2.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "iconv-lite": "^0.7.2",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.424.0",

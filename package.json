{
  "name": "meow-agent",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "electron:dev": "tsc -p tsconfig.electron.json && electron . --no-sandbox",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\" \"npm run electron:dev\""
  },
